		"@sveltejs/kit": "^2.20.8",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/vite": "^4.1.5",
		"@types/bun": "^1.2.12",
		"@types/luxon": "^3.6.2",
		"daisyui": "^5.0.35",
		"drizzle-kit": "^0.30.6",
		"eslint": "^9.26.0",
